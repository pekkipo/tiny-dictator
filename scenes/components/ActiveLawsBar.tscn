[gd_scene load_steps=2 format=3 uid="uid://clbar001tiny"]

[ext_resource type="Script" path="res://scripts/ui/ActiveLawsBar.gd" id="1_laws"]

[node name="ActiveLawsBar" type="PanelContainer"]
script = ExtResource("1_laws")

[node name="LawsMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 12

[node name="LawsVBox" type="VBoxContainer" parent="LawsMargin"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="HeaderLabel" type="Label" parent="LawsMargin/LawsVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.75, 0.75, 0.78, 1)
theme_override_font_sizes/font_size = 20
text = "ACTIVE LAWS"

[node name="LawsFlow" type="HFlowContainer" parent="LawsMargin/LawsVBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/h_separation = 24
